PORT=3333
GEMINI_API_KEY="sua-chave-aqui"
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_MODEL_FALLBACK="gemini-2.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash-lite"
DATABASE_URL="postgresql://docker:docker@localhost:5433/agents"
DEFAULT_USER_ID="00000000-0000-4000-8000-000000000001"
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"
# Origens permitidas no CORS (separadas por virgula). Em prod: URL do front no Vercel.
CORS_ORIGIN="http://localhost:5173"
LOG_LEVEL=debug
